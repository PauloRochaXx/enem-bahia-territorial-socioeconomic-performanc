# =====================================================
# DATA LAYER
# =====================================================

# Raw data (never version)
data/raw/

# Processed data (derived artifacts - do not version)
data/processed/

# External or temporary data dumps
data/external/
data/interim/


# =====================================================
# OUTPUTS / ARTIFACTS
# =====================================================

# Reports and generated documents
outputs/
reports/

# Model artifacts
models/
*.pkl
*.joblib
*.h5


# =====================================================
# PYTHON
# =====================================================

__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Packaging
build/
dist/
*.egg-info/


# =====================================================
# JUPYTER
# =====================================================

.ipynb_checkpoints/


# =====================================================
# R
# =====================================================

.Rhistory
.RData
.Rproj.user/


# =====================================================
# IDEs / EDITORS
# =====================================================

.vscode/
.idea/


# =====================================================
# OS FILES
# =====================================================

.DS_Store
Thumbs.db


# =====================================================
# LOGS / TEMP FILES
# =====================================================

*.log
*.tmp
*.swp
*.bak
